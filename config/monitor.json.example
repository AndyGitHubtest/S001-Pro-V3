{
  "telegram": {
    "bot_token": "YOUR_BOT_TOKEN",
    "chat_id": "YOUR_CHAT_ID"
  },
  "enable_tg": true,
  "database": "data/klines.db",
  "cycle_interval": 60,
  "alert_thresholds": {
    "max_latency_ms": 5000,
    "min_success_rate": 95
  },
  "monitor": {
    "log_file": "logs/chain_monitor.jsonl",
    "summary_interval": 300
  }
}
